# ── Supabase ───────────────────────────────────────────────────────────────
# From your Supabase project: Settings → API. The app runs WITHOUT these (it
# falls back to the local seed.json), but auth, gating, and telemetry need them.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key — server-only, NEVER exposed to the client. Used by the seed
# script and the dashboard's event reads.
SUPABASE_SERVICE_ROLE_KEY=

# ── PostHog (telemetry) ──────────────────────────────────────────────────────
# Optional. If unset, tracking is a no-op. Project API key + host.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
